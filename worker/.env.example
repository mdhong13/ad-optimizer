# 본인 PC 에 worker/.env 로 복사하고 채워 넣기
# .env 는 gitignore 되어있음. 절대 커밋 X.

# Railway 측 KNOWIN_WORKER_API_KEY 와 동일한 값
KNOWIN_WORKER_API_KEY=

# ad-optimizer 서버 URL
KNOWIN_BASE_URL=https://adteam.onemsg.net

# Worker 식별 (여러 PC 운영 시 구분)
KNOWIN_WORKER_ID=local-pc-1

# 일 한도 (CLI --daily-limit 으로도 override)
KNOWIN_DAILY_LIMIT=5
