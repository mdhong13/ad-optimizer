# ad-optimizer 광고 환경변수 템플릿
#
# 사용법:
#   1. 이 파일을 .env 로 복사 (또는 D:\0_Dotcell\.env.global 에 채움)
#   2. ad-optimizer는 .env.global → 프로젝트 .env 순서로 로드 (config/settings.py)
#   3. 실제 키 값은 절대 git commit 하지 말 것 (.gitignore 확인)
#
# 모든 키의 실제 값은 D:\0_Dotcell\.env.global 중앙 관리
# 이 파일은 "어떤 변수가 필요한가" 의 카탈로그일 뿐 placeholder 만 포함


# ════════════════════════════════════════════════════════════
# 🧠  LLM (광고 카피·전략 판단)
# ════════════════════════════════════════════════════════════

# Claude API — 전략 판단, 캠페인 살릴지/죽일지, 리포트 분석
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — 보조 (GPT-4o for 이미지 분석 등)
OPENAI_API_KEY=sk-...

# Gemini — 보조
GEMINI_API_KEY=...

# 로컬 LLM (d4win 서버) — 대량 카피·바이럴 생성
LOCAL_LLM_BASE_URL=http://d4win.iptime.org:31088
LOCAL_LLM_CHAT_ENDPOINT=/v1/chat/completions
LOCAL_LLM_MODELS_ENDPOINT=/v1/models


# ════════════════════════════════════════════════════════════
# 🎤  TTS (영상 보이스오버)
# ════════════════════════════════════════════════════════════

ELEVENLABS_API_KEY=...
TYPECAST_API_KEY=...


# ════════════════════════════════════════════════════════════
# 🟦  Meta Ads (Facebook + Instagram + Audience Network + Messenger)
# ════════════════════════════════════════════════════════════
# Graph API v21.0
# 광고 계정 생성 후 Business Manager에서 발급
# OneMessage 캠페인용 → docs/platforms/README.md 참조

META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=

# 광고 계정 ID — act_xxxxxxxxxxxxxxxxx 형식
META_AD_ACCOUNT_ID=act_xxxxxxxxxxxxxxx
# 복수 계정 사용 시 — 형식: "act_xxx:라벨,act_yyy:라벨2"
META_AD_ACCOUNTS=

# AdCreative.object_story_spec.page_id 용
META_PAGE_ID=

# 랜딩 페이지 (onemsg.net) 의 Meta Pixel 15자리 ID
# Phase 1 LPV 최적화에 필요. 앱 install 캠페인은 facebook_app_events SDK 별도
META_PIXEL_ID=


# ════════════════════════════════════════════════════════════
# 🔴  Google Ads (Search + YouTube + Display)
# ════════════════════════════════════════════════════════════
# API v21 (google-ads-python 28.x)
# Basic Access 신청 필요. 신청 거절 시 docs/api_access/ 참조

GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=

# Customer ID — 하이픈 없이
GOOGLE_ADS_CUSTOMER_ID=7958648888
# MCC (매니저) ID — 하이픈 없이
GOOGLE_ADS_LOGIN_CUSTOMER_ID=4894234221


# ════════════════════════════════════════════════════════════
# 📺  YouTube (Data API v3)
# ════════════════════════════════════════════════════════════

# OneMessage 채널 (mdhong13@gmail.com)
YOUTUBE_ONEMSG_API_KEY=
YOUTUBE_ONEMSG_OAUTH_CLIENT_ID=
YOUTUBE_ONEMSG_OAUTH_CLIENT_SECRET=
YOUTUBE_ONEMSG_OAUTH_REFRESH_TOKEN=

# QuantumCat 채널 (bungbungcar13@gmail.com) — 참조용
YOUTUBE_QCAT_API_KEY=


# ════════════════════════════════════════════════════════════
# 🐦  X (Twitter) Ads
# ════════════════════════════════════════════════════════════
# @onemsgx 계정 (mdhong13@gmail.com)

TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
TWITTER_BEARER_TOKEN=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# X Ads API 광고 계정 ID — Ads API 승인 후 발급
TWITTER_ADS_ACCOUNT_ID=


# ════════════════════════════════════════════════════════════
# 🟠  Reddit Ads
# ════════════════════════════════════════════════════════════
# 앱 등록: https://reddit.com/prefs/apps (script 타입)
# 광고 계정: https://ads.reddit.com

REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_REFRESH_TOKEN=
# 광고 계정 ID — a2_xxx 형식
REDDIT_ADS_ACCOUNT_ID=
REDDIT_USER_AGENT=OneMsg-Ad-Optimizer/1.0 by onemsgx


# ════════════════════════════════════════════════════════════
# 🟧  Coupang (B2C 상품 광고 — 미구현)
# ════════════════════════════════════════════════════════════
# 쿠팡 Wing 광고 시스템 (UI 운영)
# Open API: Partners API 별도 신청 필요 — 일반 셀러는 UI 운영 권장
# 전략: docs/ad_guide/ad_coupang.md 참조 (End ROAS 기반)
#
# 자동화 대신 운영 보조 데이터:
#   - 상품별 매입가/판매가/순이익 (End ROAS 계산용)
#   - 일자별 광고비/매출/자연매출 (총수익 산출용)

# Partners API (선택, 승인 시)
COUPANG_PARTNERS_ACCESS_KEY=
COUPANG_PARTNERS_SECRET_KEY=
# Vendor ID
COUPANG_VENDOR_ID=

# 상품별 손익 시트 위치 (Google Sheets)
COUPANG_PNL_SHEET_ID=
# 상품별 End ROAS 자동 계산용


# ════════════════════════════════════════════════════════════
# 🟢  Naver (브랜드검색 / GFA — 미구현)
# ════════════════════════════════════════════════════════════
# 검색광고: https://searchad.naver.com
# GFA: https://gfa.naver.com

NAVER_AD_API_KEY=
NAVER_AD_SECRET_KEY=
NAVER_AD_CUSTOMER_ID=


# ════════════════════════════════════════════════════════════
# 📧  Gmail (리포트 발송)
# ════════════════════════════════════════════════════════════

GMAIL_REFRESH_TOKEN=


# ════════════════════════════════════════════════════════════
# 💬  Threads (Meta)
# ════════════════════════════════════════════════════════════

THREADS_APP_ID=
THREADS_APP_SECRET=


# ════════════════════════════════════════════════════════════
# 🗄️  MongoDB (캠페인 데이터)
# ════════════════════════════════════════════════════════════
# AWS EC2 (ap-northeast-2)

MONGODB_URI=mongodb://USER:PASSWORD@host:27017/

# ad-optimizer 전용 DB. 절대 'lastmessage' (OneMessage 백엔드) 와 공유 금지.
# storage/db.py 에 forbidden DB 가드 있음
AD_OPTIMIZER_DB=ad_optimizer


# ════════════════════════════════════════════════════════════
# ⚙️  앱 동작 모드
# ════════════════════════════════════════════════════════════

# development | production
APP_ENV=development

# true면 모든 mutating API 호출 차단 (로그만)
DRY_RUN=true

# 자동 스케줄러 가동 여부. 기본 false (Railway·서버 배포 = 자동 가동 금지)
# 의도된 운영 시에만 명시적 true. 2026-05-28 사고 후 도입 (web/main.py)
AUTO_START_SCHEDULER=false

# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO


# ════════════════════════════════════════════════════════════
# 🛡️  안전 캡 (DRY_RUN=false 일 때만 효력)
# ════════════════════════════════════════════════════════════
# 통화: 광고 계정 통화 major unit (KRW면 원, USD면 달러)
# KR 기본값 기준

# 계정 전체 일 예산 상한
DAILY_BUDGET_CAP=40000

# 캠페인당 일 예산 상한
MAX_DAILY_BUDGET_PER_CAMPAIGN=4000

# 캠페인당 일 예산 하한 (학습 망가지는 최저값 방어)
MIN_DAILY_BUDGET_PER_CAMPAIGN=1500

# 동시 활성 캠페인 수
MAX_ACTIVE_CAMPAIGNS=25

# 단일 사이클 예산 변경 폭 (%)
BUDGET_CHANGE_LIMIT_PCT=30

# 활성화 자동? false면 항상 PAUSED 생성 → 사람이 활성화
AUTO_ACTIVATE=false

# 카나리 모드 — 첫 사이클 N개만 (안전 검증)
CANARY_MODE=true
CANARY_COUNT=3


# ════════════════════════════════════════════════════════════
# 🔄  캠페인 최적화 사이클
# ════════════════════════════════════════════════════════════

# 사이클 주기 (시간)
CAMPAIGN_CYCLE_HOURS=8

# 사이클당 생성 캠페인 수 (20→2 생존)
CAMPAIGNS_PER_CYCLE=20

# 사이클당 생존 캠페인 수
CAMPAIGNS_SURVIVE=2
