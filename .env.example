# =============================================
# OneMessage Ad Optimizer - Environment Config
# =============================================

# Anthropic (LLM Agent)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Meta Ads (Facebook + Instagram)
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_ACCESS_TOKEN=your_meta_long_lived_access_token
META_AD_ACCOUNT_ID=act_your_ad_account_id

# Google Ads
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token
GOOGLE_ADS_CLIENT_ID=your_oauth_client_id
GOOGLE_ADS_CLIENT_SECRET=your_oauth_client_secret
GOOGLE_ADS_REFRESH_TOKEN=your_refresh_token
GOOGLE_ADS_CUSTOMER_ID=your_customer_id

# Twitter/X Ads (future)
# TWITTER_API_KEY=
# TWITTER_API_SECRET=
# TWITTER_ACCESS_TOKEN=
# TWITTER_ACCESS_TOKEN_SECRET=
# TWITTER_AD_ACCOUNT_ID=

# CoinGecko (free API, no key required by default)
# COINGECKO_API_KEY=optional_pro_key

# App Settings
APP_ENV=development
DRY_RUN=true
LOG_LEVEL=INFO
DB_PATH=./storage/ad_optimizer.db

# Agent Settings
AGENT_AUTO_EXECUTE=false
BUDGET_CHANGE_LIMIT_PCT=30
